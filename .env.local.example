# Required: OpenAI API key for research synthesis and draft generation
OPENAI_API_KEY=sk-...

# Optional: Tavily API key for web search (get free tier at tavily.com)
# Without this, the app uses the model's knowledge only.
# TAVILY_API_KEY=tvly-...

# Optional: One-click publish to LinkedIn (OAuth + Posts API)
# Create an app at https://www.linkedin.com/developers/apps and add the "Share on LinkedIn" product.
# Set redirect URL in the app to: https://your-domain.com/api/linkedin/callback (or http://localhost:3000/api/linkedin/callback for local)
# LINKEDIN_CLIENT_ID=your_client_id
# LINKEDIN_CLIENT_SECRET=your_client_secret
# LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback
